# docker compose .env ć–‡ä»¶
REGISTRY_URL=registry.cn-hangzhou.aliyuncs.com/example
IMAGE_ID=latest
MYSQL_DATABASE=example
MYSQL_USER=develop
MYSQL_PASSWORD=develop
Balance_TLS_Port=:56888
Balance_TCP_Port=:26888
Balance_HTTP_Port=:16888
Chat_Port=:50051
Social_Port=:50052
Proxy_Port=:50053
Activity_Port=:50054
Item_Port=:50055
Mail_Port=:50056
GM_Port=:50057
Chat_Service=chat${Chat_Port}
Social_Service=social${Social_Port}
Proxy_Service=proxy${Proxy_Port}
Activity_Service=activity${Activity_Port}
Item_Service=item${Item_Port}
Mail_Service=mail${Mail_Port}
GM_Service=gm${GM_Port}
Redis_Service=redis-1:6379,redis-2:6379,redis-3:6379,redis-4:6379,redis-5:6379,redis-6:6379
Nats_Service=nats://nats-1:4222,nats://nats-2:4222,nats://nats-3:4222
MYSQL_DSN=${MYSQL_USER}:${MYSQL_PASSWORD}@tcp(mysql:3306)/${MYSQL_DATABASE}?charset=utf8&parseTime=True&loc=Local&readTimeout=6s&writeTimeout=6s