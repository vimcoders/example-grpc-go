{
  "protobuf.includes": [
    "${workspaceFolder}/generated/proto"
  ],
  "protobuf.formatter.enabled": true,
  "[proto3]": {
    "editor.defaultFormatter": "DrBlury.protobuf-vsc",
    "editor.formatOnSave": true
  },
  "filewatcher.commands": [
    {
      "match": "\\.proto$",
      "event": "onFileChange",
      "isAsync": false,
      "cmd": "${fileDirname}\\..\\generated-golang.bat"
    }
  ]
}
